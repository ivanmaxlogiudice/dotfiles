{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "blocks": [
        {
            "alignment": "left",
            "segments": [
                {
                    "foreground": "#45F1C2",
                    "style": "plain",
                    "template": "\ueb99 {{ .UserName }} en",
                    "type": "session"
                },
                {
                    "foreground": "#0CA0D8",
                    "options": {
                        "folder_separator_icon": "/",
                        "style": "full"
                    },
                    "style": "plain",
                    "template": " \uf07b {{ .Path }} ",
                    "type": "path"
                },
                {
                    "foreground": "#14A5AE",
                    "powerline_symbol": "\ue0b0",
                    "options": {
                        "fetch_upstream_icon": true
                    },
                    "style": "plain",
                    "template": "{{ .UpstreamIcon }}{{ .HEAD }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
                    "type": "git"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "right",
            "segments": [
                {
                    "type": "time",
                    "style": "plain",
                    "foreground": "#5E81AC",
                    "template": "\uf017 {{ .CurrentDate | date \"03:04:05 PM\" }} ",
                    "options": {
                        "time_format": "03:04:05 PM"
                    }
                },
                {
                    "type": "node",
                    "style": "plain",
                    "foreground": "#8BC34A",
                    "template": " \ue718 {{ .Full }} ",
                    "options": {
                        "display_mode": "files"
                    }
                },
                {
                    "type": "bun",
                    "style": "plain",
                    "foreground": "#fbf0df",
                    "template": "\ue76f {{ .Full }} ",
                    "options": {
                        "display_mode": "files"
                    }
                },
                {
                    "background": "transparent",
                    "foreground": "green",
                    "background_templates": [
                        "{{ if not (eq .Code 0) }}red{{ end }}"
                    ],
                    "options": {
                        "always_enabled": true,
                        "style": "round"
                    },
                    "invert_powerline": true,
                    "leading_diamond": "\ue0b6",
                    "trailing_diamond": "\ue0b4",
                    "style": "diamond",
                    "template": "{{ .FormattedMs }}",
                    "type": "executiontime"
                }
            ],
            "type": "prompt"
        },
        {
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "type": "status",
                    "style": "plain",
                    "foreground_templates": [
                        "{{ if .Error }}#FF3333{{ else }}#4CFA81{{ end }}"
                    ],
                    "template": "{{ if .Error }}✘ {{ .Code }}{{ else }}✔ {{ end }} ",
                    "options": {
                        "always_enabled": true
                    }
                },
                {
                    "foreground": "#cd5e42",
                    "style": "plain",
                    "template": "\ue3bf ",
                    "type": "root"
                },
                {
                    "foreground": "#CD4277",
                    "style": "plain",
                    "template": "# ",
                    "type": "text"
                }
            ],
            "type": "prompt"
        }
    ],
    "version": 4
}
